{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dotnet: clean",
      "command": "dotnet",
      "args": [
        "clean",
        "${workspaceFolder}/src/XtremeIdiots.Portal.Sync.App.sln",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "type": "process",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "dotnet: build",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/src/XtremeIdiots.Portal.Sync.App.sln",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "type": "process",
      "dependsOn": "dotnet: clean",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "dotnet: test",
      "command": "dotnet",
      "type": "process",
      "args": [
        "test",
        "${workspaceFolder}/src/XtremeIdiots.Portal.Sync.App.sln",
        "--filter",
        "FullyQualifiedName!~IntegrationTests",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "dotnet: format",
      "command": "dotnet",
      "args": [
        "format",
        "${workspaceFolder}/src/XtremeIdiots.Portal.Sync.App.sln",
        "--verify-no-changes"
      ],
      "type": "process",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "dotnet: clean-release",
      "command": "dotnet",
      "args": [
        "clean",
        "--configuration",
        "Release",
        "${workspaceFolder}/src/XtremeIdiots.Portal.Sync.App/XtremeIdiots.Portal.Sync.App.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "type": "process",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "dotnet: publish",
      "command": "dotnet",
      "args": [
        "publish",
        "${workspaceFolder}/src/XtremeIdiots.Portal.Sync.App/XtremeIdiots.Portal.Sync.App.csproj",
        "--configuration",
        "Release",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "type": "process",
      "dependsOn": "dotnet: clean-release",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "func: host start",
      "type": "func",
      "dependsOn": "dotnet: build",
      "options": {
        "cwd": "${workspaceFolder}/src/XtremeIdiots.Portal.Sync.App/bin/Debug/net9.0"
      },
      "command": "host start",
      "isBackground": true,
      "problemMatcher": "$func-dotnet-watch"
    }
  ]
}