{
    "version": "2.0",
    "extensions": {
        "durableTask": {
            "storageProvider": {
                "type": "AzureStorage"
            }
        }
    },
    "logging": {
        "logLevel": {
            "Function.HealthCheck": "Warning"
        },
        "applicationInsights": {
            "samplingSettings": {
                "isEnabled": true,
                "excludedTypes": "Exception"
            }
        }
    }
}