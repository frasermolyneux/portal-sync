{
  "openapi": "3.0.1",
  "info": {
    "title": "Portal Sync API",
    "version": "v1"
  },
  "components": {
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT token issued by Azure AD"
      }
    }
  },
  "security": [
    {
      "Bearer": []
    }
  ],
  "paths": {
    "/api/map-rotations/sync/{assignmentId}": {
      "post": {
        "operationId": "TriggerSyncMapRotation",
        "parameters": [
          {
            "name": "assignmentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Accepted"
          }
        }
      }
    },
    "/api/map-rotations/remove/{assignmentId}": {
      "post": {
        "operationId": "TriggerRemoveMapRotation",
        "parameters": [
          {
            "name": "assignmentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Accepted"
          }
        }
      }
    },
    "/api/map-rotations/activate/{assignmentId}": {
      "post": {
        "operationId": "TriggerActivateMapRotation",
        "parameters": [
          {
            "name": "assignmentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Accepted"
          }
        }
      }
    },
    "/api/map-rotations/deactivate/{assignmentId}": {
      "post": {
        "operationId": "TriggerDeactivateMapRotation",
        "parameters": [
          {
            "name": "assignmentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Accepted"
          }
        }
      }
    },
    "/api/map-rotations/status/{instanceId}": {
      "get": {
        "operationId": "GetMapRotationOrchestrationStatus",
        "parameters": [
          {
            "name": "instanceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/map-rotations/terminate/{instanceId}": {
      "post": {
        "operationId": "TerminateMapRotationOrchestration",
        "parameters": [
          {
            "name": "instanceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "Orchestration instance not found"
          }
        }
      }
    },
    "/api/map-rotations/verify/{assignmentId}": {
      "post": {
        "operationId": "TriggerVerifyMapRotation",
        "parameters": [
          {
            "name": "assignmentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Accepted"
          }
        }
      }
    },
    "/api/maps/push/{gameServerId}/{gameType}/{mapName}": {
      "post": {
        "operationId": "TriggerPushMapToServer",
        "parameters": [
          {
            "name": "gameServerId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "gameType",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "mapName",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Accepted"
          },
          "400": {
            "description": "Bad Request - invalid map name or game type"
          }
        }
      }
    },
    "/api/health/live": {
      "get": {
        "operationId": "HealthCheckLive",
        "security": [],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/health/ready": {
      "get": {
        "operationId": "HealthCheckReady",
        "security": [],
        "responses": {
          "200": {
            "description": "OK"
          },
          "503": {
            "description": "Service Unavailable"
          }
        }
      }
    }
  }
}